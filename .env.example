# Site URL (used for metadata / Open Graph)
NEXT_PUBLIC_SITE_URL=https://www.abjatalstar.com

# Sanity CMS (Studio at `/admin`)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Live Content API + instant publish updates (sanity.io/manage → API → Tokens → Viewer)
SANITY_API_READ_TOKEN=

# Webhook secret — same value in Sanity → API → Webhooks → your revalidate webhook
SANITY_REVALIDATE_SECRET=

# Sanity API token (sanity.io/manage → API → Tokens → Editor)
# Add to Vercel for: staff email records (/admin/email-accounts) + Sanity publish webhooks.
# Local seed script also uses this — do not commit the real value to git.
SANITY_API_TOKEN=

# Contact form (resend.com — verify abjatalstar.com domain first)
RESEND_API_KEY=
CONTACT_FORM_TO_EMAIL=info@abjatalstar.com
CONTACT_FORM_FROM_EMAIL=Abjatal Star <info@abjatalstar.com>

# Branded staff mail portal (/mail)
EMAIL_PROVIDER=manual
# Staff are sent to this branded path first, then redirected to HostGator webmail
NEXT_PUBLIC_WEBMAIL_URL=https://www.abjatalstar.com/webmail
# Copy the exact URL from HostGator cPanel → Email Accounts → Check Email / Access Webmail
WEBMAIL_DESTINATION_URL=https://webmail.abjatalstar.com
NEXT_PUBLIC_BRAND_NAME=AbjatalStar
NEXT_PUBLIC_MAIL_DOMAIN=abjatalstar.com

# Email admin dashboard (/admin/email-accounts) — choose a strong password
MAIL_ADMIN_PASSWORD=

# Optional future cPanel API (not implemented yet)
# CPANEL_HOST=
# CPANEL_USERNAME=
# CPANEL_API_TOKEN=

# Email account records persist via Sanity when SANITY_API_TOKEN is set on Vercel (recommended for production)
