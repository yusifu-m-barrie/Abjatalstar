# Site URL (used for metadata / Open Graph)
NEXT_PUBLIC_SITE_URL=https://www.abjatalstar.com

# Sanity CMS (Studio at `/admin`)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Live Content API + instant publish updates (sanity.io/manage → API → Tokens → Viewer)
SANITY_API_READ_TOKEN=

# Webhook secret — same value in Sanity → API → Webhooks → your revalidate webhook
SANITY_REVALIDATE_SECRET=

# Sanity API token (sanity.io/manage → API → Tokens → Editor)
# Add to Vercel for: staff email records (/admin/email-accounts) + Sanity publish webhooks.
# Local seed script also uses this — do not commit the real value to git.
SANITY_API_TOKEN=

# Contact form (resend.com — verify abjatalstar.com domain first)
RESEND_API_KEY=
CONTACT_FORM_TO_EMAIL=info@abjatalstar.com
CONTACT_FORM_FROM_EMAIL=Abjatal Star <info@abjatalstar.com>

# ─── Branded staff mail (Phase 1 + 2) ───────────────────────────────────────
# Mail admin auth is SEPARATE from Sanity CMS login at /admin
# Provider: manual (default) | cpanel (optional — auto-creates mailboxes when CPANEL_* is set)
EMAIL_PROVIDER=manual

# Role-based mail dashboard access (email + password per role)
MAIL_SUPER_ADMIN_EMAIL=super@abjatalstar.com
MAIL_SUPER_ADMIN_PASSWORD=

MAIL_ADMIN_EMAIL=admin@abjatalstar.com
MAIL_ADMIN_PASSWORD=

MAIL_EDITOR_EMAIL=editor@abjatalstar.com
MAIL_EDITOR_PASSWORD=

# Optional: dedicated session signing secret (falls back to admin passwords if unset)
# MAIL_SESSION_SECRET=

# HostGator cPanel API — server-side only, never exposed to browser (Super Admin configures on Vercel)
CPANEL_HOST=abjatalstar.com
CPANEL_USERNAME=
CPANEL_API_TOKEN=

# Branded webmail gateway — /mail redirects here, then /webmail → HostGator
NEXT_PUBLIC_WEBMAIL_URL=https://abjatalstar.com/webmail

# HostGator/cPanel webmail (server-only). Copy exact URL from cPanel → Email → Access Webmail.
# Use your domain on port 2096 — do NOT use webmail.abjatalstar.com unless that DNS record exists.
WEBMAIL_DESTINATION_URL=https://abjatalstar.com:2096

# Direct HostGator link for "Open Webmail Directly" on /mail
NEXT_PUBLIC_WEBMAIL_DIRECT_URL=https://abjatalstar.com:2096

NEXT_PUBLIC_BRAND_NAME=AbjatalStar
NEXT_PUBLIC_MAIL_DOMAIN=abjatalstar.com

# Protects /admin/email-accounts (legacy single-password login still works via MAIL_ADMIN_PASSWORD)
# MAIL_ADMIN_PASSWORD is used for Admin role when MAIL_ADMIN_EMAIL is unset (defaults to admin@abjatalstar.com)

# Email account records + activity logs persist via Sanity when SANITY_API_TOKEN is set on Vercel
