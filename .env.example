# Admin login (set on Vercel — never commit real values)
ADMIN_EMAIL=your-email@example.com
ADMIN_PASSWORD=your-secure-password
ADMIN_SESSION_SECRET=generate-a-long-random-string

# GitHub — CMS saves content to your repo (create a Personal Access Token with repo scope)
GITHUB_TOKEN=ghp_your_github_token
GITHUB_REPO=yusifu-m-barrie/Abjatalstar
GITHUB_BRANCH=main

# Site
NEXT_PUBLIC_SITE_URL=https://www.abjatalstar.com

# Optional — only if still using Netlify Identity proxy (not needed with custom login)
NETLIFY_SITE_URL=https://abjatalstar.netlify.app
